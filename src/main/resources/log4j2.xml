<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <!-- Appender for technical information -->
        <File name="TechnicalLog" fileName="logs/technical.log">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n"/>
        </File>
        <!-- Appender for user messages -->
        <File name="UserOutput" fileName="logs/user_output.log">
            <PatternLayout pattern="* %msg%n"/>
        </File>
    </Appenders>
    <Loggers>
        <!-- Logger for technical information -->
        <Root level="info">
            <AppenderRef ref="TechnicalLog"/>
        </Root>
        <!-- Logger for user messages -->
        <Logger name="UserLogger" level="info" additivity="false">
            <AppenderRef ref="UserOutput"/>
        </Logger>
    </Loggers>
</Configuration>